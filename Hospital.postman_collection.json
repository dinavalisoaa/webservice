              "path": ["prescriptions"],
              "query": [
                { "key": "stayId",   "value": "9", "description": "Séjour 9 (Rajoelison — fracture poignet)" },
                { "key": "doctorId", "value": "2", "description": "dr.john (ID 2)" }
              ]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prescriptionDate\": \"2026-03-29\",\n  \"instructions\": \"Prendre le soir avec un verre d'eau. Éviter l'alcool.\",\n  \"duration\": \"7 jours\",\n  \"status\": \"ACTIVE\"\n}"
            }
