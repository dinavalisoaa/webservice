          "name": "Update Prescription",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/prescriptions/7",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prescriptionDate\": \"2026-03-24\",\n  \"instructions\": \"Terminer le traitement antibiotique même si amélioration des symptômes.\",\n  \"duration\": \"10 jours\",\n  \"status\": \"ACTIVE\"\n}"
            }
          }
        },
        {
          "name": "Dispense Prescription (prescription 2 — ACTIVE)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/prescriptions/2/dispense",
            "description": "Décrémente le stock de chaque médicament atomiquement. Échoue si stock insuffisant (409)."
