    {
      "name": "Prescriptions",
      "description": "Prescriptions liées aux séjours. dispense/cancel uniquement si status=ACTIVE.",
      "item": [
        {
          "name": "Get All Prescriptions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/prescriptions"
          }
        },
        {
          "name": "Get Prescription by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/prescriptions/2"
          }
        },
        {
          "name": "Get Prescription Medications",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/prescriptions/4/medications",
            "description": "Prescription 4 (séjour 4, cardiac arrest) — contient Morphine, Atenolol, Dexamethasone"
          }
        },
        {
          "name": "Create Prescription",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/prescriptions?stayId=9&doctorId=2",
