    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  try {",
                  "    const responseBody = pm.response.json();",
                  "    let token;",
                  "    ",
                  "    // Extract token from response (adjust based on your API's response structure)",
                  "    // Common patterns: response.token, response.data.token, response.accessToken, or the entire response",
                  "    if (responseBody.token) {",
                  "      token = responseBody.token;",
                  "    } else if (responseBody.accessToken) {",
                  "      token = responseBody.accessToken;",
                  "    } else if (responseBody.data && responseBody.data.token) {",
                  "      token = responseBody.data.token;",
                  "    } else if (typeof responseBody === 'string') {",
                  "      token = responseBody;",
                  "    }",
                  "    ",
                  "    if (token) {",
                  "      pm.collectionVariables.set('Token', token);",
                  "      pm.test('Token saved successfully', function() {",
                  "        pm.expect(token).to.not.be.empty;",
                  "        pm.expect(token).to.be.a('string');",
                  "      });",
                  "      console.log('✓ Token saved: ' + token.substring(0, 20) + '...');",
                  "    } else {",
                  "      pm.test('Token extraction failed', function() {",
                  "        pm.expect.fail('Could not extract token from response. Response: ' + JSON.stringify(responseBody));",
                  "      });",
                  "    }",
                  "  } catch (error) {",
                  "    pm.test('Error parsing response', function() {",
                  "      pm.expect.fail('Failed to parse login response: ' + error.message);",
                  "    });",
                  "  }",
                  "} else {",
                  "  pm.test('Login failed', function() {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "  });",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{Token}}",
